{
  "name": "base-bailey-json",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "src/app.js",
  "type": "module",
  "engines": {
    "node": ">=24.17.0",
    "npm": ">=11.13.0"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "lint": "eslint . --no-ignore",
    "dev": "npm run lint && nodemon --signal SIGKILL ./src/app.js",
    "start": "node ./src/app.js",
    "check-updates": "ncu",
    "update-deps": "ncu -u && npm install",
    "audit": "npm audit",
    "outdated": "npm outdated",
    "duplicates": "npm ls",
    "health": "npm audit && npm outdated && npm ls",
    "clean": "rimraf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install"
  },
  "keywords": [],
  "dependencies": {
    "@builderbot/bot": "1.4.2",
    "@builderbot/database-mysql": "1.4.2",
    "@builderbot/provider-baileys": "1.4.2",
    "baileys": "^7.0.0-rc13"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-plugin-builderbot": "latest",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^22.2.7",
    "rimraf": "^6.1.3"
  },
  "overrides": {
    "baileys": "^7.0.0-rc13",
    "cheerio": "^1.1.2"
  },
  "author": "",
  "license": "ISC",
  "allowScripts": {
    "sharp@0.33.3": true,
    "sharp@0.35.2": true,
